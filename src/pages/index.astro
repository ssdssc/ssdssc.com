---
// Temporary SSDSSC Homepage — Black & Gold
import Analytics from '@vercel/analytics/astro'
export const prerender = true;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SSDSSC – Science Society of D.S. Senanayake College</title>
    <meta
      name="description"
      content="The Science Society of D.S. Senanayake College (SSDSSC) — Sri Lanka's leading school science society, organizing national-level events, innovation awards, and science programs."
    />
    <link rel="canonical" href="https://ssdssc.com/" />
    <meta
      property="og:title"
      content="SSDSSC – Science Society of D.S. Senanayake College"
    />
    <meta
      property="og:description"
      content="Sri Lanka's leading school science society, organizing national-level events, innovation awards, and science programs."
    />
    <meta property="og:url" content="https://ssdssc.com/" />
    <meta property="og:type" content="website" />
    <meta
      property="og:image"
      content="https://ssdssc.com/esper/images/vkkj1t1sjcafcrep0jyx09zbh8.png"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="SSDSSC – Science Society of D.S. Senanayake College"
    />
    <meta
      name="twitter:description"
      content="Sri Lanka's leading school science society."
    />
    <meta
      name="twitter:image"
      content="https://ssdssc.com/esper/images/vkkj1t1sjcafcrep0jyx09zbh8.png"
    />
    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/ssdssc/favicon.ico" />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/ssdssc/favicon-16x16.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/ssdssc/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="192x192"
      href="/ssdssc/android-chrome-192x192.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="512x512"
      href="/ssdssc/android-chrome-512x512.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/ssdssc/apple-touch-icon.png"
    />
    <link rel="manifest" href="/ssdssc/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: "Inter", sans-serif;
        background: #0a0a0a;
        color: #f5f0e8;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }

      .page {
        text-align: center;
        padding: 2rem;
        max-width: 560px;
      }

      .line-top {
        width: 40px;
        height: 1px;
        background: #c9a84c;
        margin: 0 auto 2.5rem;
      }

      .label {
        font-family: "Inter", sans-serif;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #c9a84c;
        margin-bottom: 0.5rem;
      }

      h1 {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(2.2rem, 5vw, 3.4rem);
        font-weight: 300;
        line-height: 1.2;
        color: #f5f0e8;
        margin-bottom: 1.5rem;
        letter-spacing: 0.02em;
      }

      h1 span {
        color: #c9a84c;
        font-weight: 600;
      }

      .line-bottom {
        width: 40px;
        height: 1px;
        background: #c9a84c;
        margin: 0 auto 1.5rem;
      }

      .logo {
        width: 140px;
        height: 140px;
        object-fit: contain;
        margin: 0 auto 0.25rem;
        display: block;
      }

      .subtitle {
        font-size: 0.85rem;
        color: rgba(245, 240, 232, 0.45);
        line-height: 1.8;
        margin-bottom: 3rem;
        font-weight: 400;
      }

      .btn {
        display: inline-block;
        background: #c9a84c;
        color: #0a0a0a;
        text-decoration: none;
        padding: 13px 36px;
        font-family: "Inter", sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        transition:
          background 0.2s ease,
          transform 0.2s ease;
      }

      .btn:hover {
        background: #e0bc6a;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(201, 168, 76, 0.2);
      }

      .btn-evo {
        background: rgb(114, 59, 255) !important;
        color: #ffffff !important;
      }

      .btn-evo:hover {
        background: rgb(130, 80, 255) !important;
        box-shadow: 0 4px 12px rgba(114, 59, 255, 0.4);
      }

      .btn-group {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        margin-top: 0.5rem;
        width: 100%;
      }

      .btn-esper,
      .btn-evo {
        width: 240px;
        text-align: center;
      }

      footer {
        position: fixed;
        bottom: 1.75rem;
        width: 100%;
        text-align: center;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        color: rgba(245, 240, 232, 0.2);
        text-transform: uppercase;
      }
    </style>
  </head>
  <body>
    <div class="page">
      <div class="line-top"></div>
      <p class="label">Colombo 7 · Est. D.S. Senanayake College</p>
      <img src="/ssdssc/logo.png" alt="SSDSSC Logo" class="logo" />
      <h1>Science Society of<br /><span>D.S. Senanayake</span><br />College</h1>
      <div class="line-bottom"></div>
      <p class="subtitle">
        Sri Lanka's leading school science society — celebrating innovation,<br
        />
        research and young scientific minds across the island.
      </p>
      <div class="btn-group">
        <a href="/esper" class="btn btn-esper" id="esper-link">ESPER Awards '26</a>
        <a href="/evo" class="btn btn-evo" id="evo-link">Evolvion '26</a>
      </div>
    </div>

    <footer>© 2026 SSDSSC · All Rights Reserved</footer>
    <Analytics />
  </body>
</html>
